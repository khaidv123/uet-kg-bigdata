# Copy this file to `.env` for local or SSH-host execution.
# Do not commit real secrets to the repository.

PROJECT_NAME=data-ingestion
ENVIRONMENT=dev

AIRFLOW_UID=1000
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_FIRSTNAME=Data
AIRFLOW_ADMIN_LASTNAME=Ingestion
AIRFLOW_ADMIN_EMAIL=admin@example.local
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__FERNET_KEY=6IDjc6D7nCkUlfM2O4Rj4J5iL5S8mYJ9tC6kA3rN0Q8=
AIRFLOW__WEBSERVER__SECRET_KEY=airflow-webserver-secret-dev-only
AIRFLOW_SMOKE_CONFIG_PATH=/opt/project/config/airflow_smoke_config.json
AIRFLOW_SMOKE_REPORT_PATH=/opt/project/metadata/airflow_smoke_report.json

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_RAW=uet-raw
MINIO_BUCKET_META=uet-meta

METADATA_DB_PATH=metadata/crawl_state.db
LOGGING_CONFIG_PATH=config/logging.yaml
PDF_URL_DISCOVERY_PATH=metadata/discovered_pdf_urls.jsonl

INGESTION_DAG_SCHEDULE=@once
INGESTION_DEMO_ITERATIONS=1
INGESTION_MAX_PAGES_PER_SOURCE=500
INGESTION_SOURCE_ID=all
INGESTION_REGISTRY_PATH=/opt/project/config/sources.yaml
INGESTION_ARTIFACT_DIR=/opt/project/metadata/full_batch_runs/2026-04-18/ingestion_runs
INGESTION_MANIFEST_PATH=/opt/project/metadata/full_batch_runs/2026-04-18/ingestion_manifest.json
INGESTION_QUALITY_REPORT_PATH=/opt/project/metadata/full_batch_runs/2026-04-18/ingestion_quality_report.json
QUALITY_MIN_TITLE_RATIO=0.95
QUALITY_MIN_TEXT_PREVIEW_RATIO=0.95
QUALITY_MIN_METADATA_COMPLETENESS_RATIO=1.0
QUALITY_MIN_OBJECT_MATCH_RATIO=1.0
QUALITY_MAX_ERROR_COUNT=25
CRAWLER_DOWNLOAD_TIMEOUT=45
CRAWLER_RETRY_TIMES=4
INGESTION_TASK_TIMEOUT_MINUTES=360
INGESTION_TASK_RETRIES=2
INGESTION_TASK_RETRY_DELAY_MINUTES=5

SEED_SOURCES_CONFIG=config/seeds.yaml
CRAWLER_SOURCE_NAME=uet
CRAWLER_USER_AGENT=data-ingestion-bot/0.1
CRAWLER_RUNTIME_COMMAND=sleep infinity
